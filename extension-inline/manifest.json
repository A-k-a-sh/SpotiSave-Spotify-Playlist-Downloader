{
  "manifest_version": 3,
  "name": "Spotify Playlist Downloader (Inline)",
  "version": "1.0.0",
  "description": "Download Spotify playlist tracks directly from the page with inline selection",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://open.spotify.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/playlist/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
